// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                String             @id @default(uuid())
  name              String
  url               String?
  logo              String?
  primaryColor      String?            @map("primary_color")
  users             User[]
  beds              Bed[]
  appointments      Appointment[]
  labBookings       LabBooking[]
  radiologyBookings RadiologyBooking[]
  medicines         Medicine[]
  suppliers         Supplier[]
  invoices          Invoice[]

  @@map("tenants")
}

model User {
  id        String  @id @default(uuid())
  tenantId  String  @map("tenant_id")
  name      String
  email     String  @unique
  password  String
  role      String // 'admin', 'doctor', 'patient', 'superadmin'
  specialty String?
  avatar    String?
  tenant    Tenant  @relation(fields: [tenantId], references: [id])

  patientAppointments Appointment[]      @relation("PatientAppointments")
  doctorAppointments  Appointment[]      @relation("DoctorAppointments")
  labBookings         LabBooking[]
  radiologyBookings   RadiologyBooking[]
  beds                Bed[]
  invoices            Invoice[]


  @@map("users")
}

model Bed {
  id        String  @id @default(uuid())
  tenantId  String  @map("tenant_id")
  floor     Int
  room      String
  status    String // 'available', 'occupied', 'cleaning', 'maintenance'
  patientId String? @map("patient_id")
  tenant    Tenant  @relation(fields: [tenantId], references: [id])
  patient   User?   @relation(fields: [patientId], references: [id])

  @@map("beds")
}

model Appointment {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  patientId String   @map("patient_id")
  doctorId  String   @map("doctor_id")
  startTime DateTime @map("start_time")
  status    String // 'scheduled', 'completed', 'cancelled', 'waiting'
  reason    String?
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  patient   User     @relation("PatientAppointments", fields: [patientId], references: [id])
  doctor    User     @relation("DoctorAppointments", fields: [doctorId], references: [id])

  @@map("appointments")
}

model LabBooking {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  patientId String
  patient   User     @relation(fields: [patientId], references: [id])
  test      String
  status    String   @default("pending") // 'pending', 'completed', 'cancelled'
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RadiologyBooking {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  patientId String
  patient   User     @relation(fields: [patientId], references: [id])
  test      String
  status    String   @default("pending") // 'pending', 'completed', 'cancelled'
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Medicine {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  name       String
  stock      Int
  expiryDate DateTime
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

}

model Supplier {
  id        String     @id @default(cuid())
  tenantId  String
  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  name      String
  contact   String
  medicines Medicine[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

}

model Invoice {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  patientId String
  patient   User     @relation(fields: [patientId], references: [id])
  amount    Float
  status    String   @default("pending") // 'pending', 'paid', 'cancelled'
  items     Json     // Array of { description: string, cost: number }
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
